{
  "expo": {
    "name": "JOJ Dakar 2026",
    "slug": "joj-superapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/dakarlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050A18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.joj.superapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050A18"
      },
      "package": "com.joj.superapp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050A18",
          "image": "./assets/dakarlogo.png"
        }
      ]
    ],
    "scheme": "joj",
    "extra": {
      "eas": {
        "projectId": "075098d6-4a1a-4d75-b1fa-eb1c9b209692"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "owner": "abdoullah2025"
  }
}
